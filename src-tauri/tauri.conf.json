{
    "$schema":  "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
    "productName":  "织梦机",
    "version":  "0.0.1",
    "identifier":  "com.zhimengji.app",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "织梦机",
                                    "width":  1200,
                                    "height":  800,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "label":  "main"
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [

                            ]
               }
}
